{
  "name": "electron-forge-maker-innosetup",
  "version": "1.0.0",
  "description": "An Electron Forge maker for creating Windows installers using Inno Setup with full TypeScript support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:clean": "rimraf dist && tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepublishOnly": "npm run build && npm test",
    "setup-portable": "node scripts/setup-portable.js"
  },
  "dependencies": {
    "@electron-forge/maker-base": "^7.0.0",
    "@electron-forge/shared-types": "^7.0.0",
    "debug": "^4.3.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/debug": "^4.1.12",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.39.4",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.1"
  },
  "files": [
    "dist/**/*",
    "vendor/**/*",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "electron",
    "electron-forge",
    "maker",
    "innosetup",
    "inno-setup",
    "installer",
    "windows",
    "setup",
    "typescript"
  ],
  "author": "xunrua",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/promisemey/electron-forge-maker-innosetup.git"
  },
  "bugs": {
    "url": "https://github.com/promisemey/electron-forge-maker-innosetup/issues"
  },
  "homepage": "https://github.com/promisemey/electron-forge-maker-innosetup#readme",
  "engines": {
    "node": ">=18.0.0"
  }
}
